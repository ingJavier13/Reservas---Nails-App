generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---
enum Role {
  CLIENTE
  TRABAJADOR
  ADMIN
}

enum Status {
  PENDIENTE
  CONFIRMADA
  CANCELADA
  COMPLETADA
}

enum UnitType {
  PIEZA
  MILILITROS
  GRAMOS
}

// --- MODELOS ---
model User {
  id            Int           @id @default(autoincrement())
  email         String        @unique
  password      String
  name          String
  phone         String?       // Agregado para WhatsApp/Llamadas
  role          Role          @default(CLIENTE)
  createdAt     DateTime      @default(now())
  
  // Relaciones (Un usuario puede ser cliente o trabajador en una cita)
  appointments  Appointment[] @relation("CustomerAppointments")
  workSchedules Appointment[] @relation("WorkerAppointments")
}

model Service {
  id           Int           @id @default(autoincrement())
  name         String
  description  String?
  price        Float
  duration     Int           // Duración en minutos
  imageUrl     String?       // IMAGEN DEL SERVICIO
  
  appointments Appointment[]
  materials    ServiceMaterial[]
}

model Appointment {
  id                 Int      @id @default(autoincrement())
  date               DateTime
  status             Status   @default(PENDIENTE)
  cancellationReason String?  // <- Motivo capturado en el nuevo popup
  createdAt          DateTime @default(now())

  // Relación 1: El Cliente que agendó
  userId    Int
  user      User     @relation("CustomerAppointments", fields: [userId], references: [id])

  // Relación 2: La Manicurista asignada (Opcional al principio)
  workerId  Int?     
  worker    User?    @relation("WorkerAppointments", fields: [workerId], references: [id])

  // Relación 3: El Servicio
  serviceId Int
  service   Service  @relation(fields: [serviceId], references: [id])
}

model Material {
  id          Int      @id @default(autoincrement())
  name        String
  currentStock Float   @default(0)
  minStock    Float    @default(0)
  unit        UnitType @default(PIEZA)
  costPerUnit Float?    // Para estadísticas/finanzas
  
  services    ServiceMaterial[]
  createdAt   DateTime @default(now())
}

model ServiceMaterial {
  id         Int      @id @default(autoincrement())
  serviceId  Int
  materialId Int
  quantity   Float    // Cantidad descontada en cada servicio
  
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([serviceId, materialId])
}

model Expense {
  id          Int      @id @default(autoincrement())
  description String
  amount      Float
  date        DateTime @default(now())
}